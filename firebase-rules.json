{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['displayName', 'email', 'coins'])"
      }
    },
    
    "calls": {
      "$callId": {
        ".read": "auth != null",
        ".write": "auth != null && (data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid || newData.child('callerId').val() === auth.uid || newData.child('receiverId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['callerId', 'receiverId', 'status'])"
      }
    },
    
    "notifications": {
      "$userId": {
        "$notificationId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && (newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid)"
        }
      }
    },
    
    "payments": {
      "$userId": {
        "$paymentId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    }
  }
}
