{
  "rules": {
    ".read": false,
    ".write": false,
    
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false,
        
        "coins": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        },
        
        "isAdmin": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      }
    },
    
    "publicProfiles": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid"
      },
      ".indexOn": ["isAvailable", "profileId"]
    },
    
    "calls": {
      "$callId": {
        ".read": "auth != null && (
          auth.uid === data.child('callerId').val() ||
          auth.uid === data.child('whisperId').val() ||
          root.child('users/'+auth.uid+'/isAdmin').val() === true
        )",
        ".write": false
      }
    },
    
    "reviews": {
      "$callId": {
        ".read": "auth != null && root.child('users/'+auth.uid+'/isAdmin').val() === true",
        ".write": "auth != null"
      }
    },
    
    "adminActions": {
      ".read": "auth != null && root.child('users/'+auth.uid+'/isAdmin').val() === true",
      ".write": "auth != null && root.child('users/'+auth.uid+'/isAdmin').val() === true"
    },
    
    "callDisputes": {
      "$callId": {
        ".read": "auth != null && root.child('users/'+auth.uid+'/isAdmin').val() === true",
        ".write": "auth != null && (
          auth.uid === data.child('callerId').val() ||
          auth.uid === data.child('whisperId').val() ||
          root.child('users/'+auth.uid+'/isAdmin').val() === true
        )"
      }
    },
    
    "abuseStats": {
      "$uid": {
        ".read": "auth != null && root.child('users/'+auth.uid+'/isAdmin').val() === true",
        ".write": false
      }
    },
    
    "rateLimits": {
      "$uid": {
        ".read": false,
        ".write": false
      }
    },
    
    "heartbeats": {
      "$callId": {
        ".read": "auth != null && (
          auth.uid === data.child('callerId').val() ||
          auth.uid === data.child('whisperId').val() ||
          root.child('users/'+auth.uid+'/isAdmin').val() === true
        )",
        ".write": "auth != null"
      }
    }
  }
}
